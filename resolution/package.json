{
  "name": "@sigarena/resolution",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-driven market resolution agent for SIG Arena",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "resolution": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "resolve": "tsx src/cli.ts start",
    "resolve:once": "tsx src/cli.ts once",
    "resolve:status": "tsx src/cli.ts status",
    "resolve:custom": "tsx src/cli.ts custom",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/xai": "^2.0.39",
    "@hono/node-server": "^1.14.1",
    "@sigarena/common": "workspace:*",
    "ai": "^5.0.108",
    "dotenv": "^16.5.0",
    "hono": "^4.7.10",
    "zod": "^3.25.30"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
