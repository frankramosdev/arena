{
  "name": "sig-arena",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    
    "registry": "pnpm --filter @sig-arena/registry start",
    "registry:dev": "pnpm --filter @sig-arena/registry dev",
    "registry:test": "pnpm --filter @sig-arena/registry test",
    
    "frontend": "pnpm --filter frontend dev",
    "frontend:build": "pnpm --filter frontend build",
    
    "generate": "pnpm --filter @sigarena/creation generate",
    "generate:once": "pnpm --filter @sigarena/creation generate:once",
    "creation:test": "pnpm --filter @sigarena/creation test",
    
    "resolve": "pnpm --filter @sigarena/resolution resolve",
    "resolve:once": "pnpm --filter @sigarena/resolution resolve:once",
    "resolve:status": "pnpm --filter @sigarena/resolution resolve:status",
    "resolve:custom": "pnpm --filter @sigarena/resolution resolve:custom",
    "resolution:test": "pnpm --filter @sigarena/resolution test",
    
    "trading": "pnpm --filter @sigarena/trading server",
    "trading:dev": "pnpm --filter @sigarena/trading dev",
    "trading:test": "pnpm --filter @sigarena/trading test",
    "trade": "pnpm --filter @sigarena/trading trade",
    "trade:once": "pnpm --filter @sigarena/trading trade:once",
    "trade:demo": "pnpm --filter @sigarena/trading demo",
    "trade:live": "pnpm --filter @sigarena/trading live",
    
    "ship": "pnpm --filter @sigarena/personality-creator ship",
    "ship:api": "pnpm --filter @sigarena/personality-creator api",
    
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "docker:ps": "docker-compose ps"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c",
  "dependencies": {
    "@xdevplatform/xdk": "^0.3.0"
  }
}
